SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Optional: migration 0011 creates/updates admin on `migrate` (also set on Render env)
# ADMIN_USER=admin
# ADMIN_PASS=change-me-strong-password
# For production (e.g. Render), set DEBUG=False and add your host:
# ALLOWED_HOSTS=your-app.onrender.com
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
# Neon (production) — direct connection string from neon.tech dashboard:
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# Local: omit DATABASE_URL to use db.sqlite3
